# Named verbs for the workspace. `just` with no argument lists them.

# Build every crate.
build:
    cargo build --workspace

# Test every crate.
test:
    cargo test --workspace

# Lint + format check — what CI would run.
check:
    cargo clippy --workspace
    cargo fmt --check

# Bring the whole POC up (fake-model, two agents, tower backend, vite).
# Multi-process orchestration is the one job cargo doesn't do; dev.sh owns it.
dev:
    ./dev.sh

# Attach the terminal client to an agent: `just tui` or `just tui agent-two`.
tui agent="agent-one":
    cargo run -q -p tui -- {{agent}}
